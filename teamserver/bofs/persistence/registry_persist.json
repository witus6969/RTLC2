{
  "name": "registry_persist",
  "category": "persistence",
  "author": "N7WEra",
  "description": "Install registry Run key persistence to execute a payload on user logon.",
  "source": "https://github.com/N7WEra/BofAllTheThings",
  "args": [
    {"name": "key_path", "type": "string", "required": true, "description": "Registry key path"},
    {"name": "value_name", "type": "string", "required": true, "description": "Registry value name"},
    {"name": "payload_path", "type": "string", "required": true, "description": "Path to payload binary"},
    {"name": "hive", "type": "string", "required": false, "description": "HKCU or HKLM, default HKCU"}
  ],
  "platforms": ["windows"],
  "opsec": "moderate"
}
